##############################################################################
# SIWIRUS — Laravel 12 + Livewire 3 + Vite
# .gitignore — Production-ready, VPS-deployed
##############################################################################

# ===========================================================================
# ENVIRONMENT & SECRETS  ← JANGAN PERNAH COMMIT INI
# ===========================================================================
.env
.env.*
!.env.example
*.backup
*.env.backup
local.env.backup
prod.env.backup
auth.json

# ===========================================================================
# PHP / COMPOSER
# ===========================================================================
/vendor
composer.phar

# ===========================================================================
# NODE / NPM
# ===========================================================================
/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===========================================================================
# VITE / FRONTEND BUILD OUTPUT
# ===========================================================================
/public/build
/public/hot

# ===========================================================================
# LARAVEL RUNTIME — jangan commit file yang di-generate saat runtime
# ===========================================================================

# Storage symlink (dibuat via `php artisan storage:link`)
/public/storage

# Encryption keys
/storage/*.key

# Bootstrap cache (di-generate via `php artisan optimize`)
/bootstrap/cache/*.php

# Framework runtime (sessions, views, cache — sudah ada nested .gitignore)
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
!/storage/framework/cache/.gitignore
!/storage/framework/sessions/.gitignore
!/storage/framework/views/.gitignore

# Logs (sudah ada nested .gitignore di storage/logs/)
/storage/logs/*.log

# Debugbar (dev tool — tidak perlu di repo)
/storage/debugbar

# Laravel Pail (dev log streaming)
/storage/pail

# ===========================================================================
# TESTING
# ===========================================================================
.phpunit.result.cache
.phpunit.cache
/.phpunit.cache
/coverage
/.nyc_output
.pest-mutate-cache

# ===========================================================================
# PHP TOOLS (dev-only)
# ===========================================================================
_ide_helper.php
_ide_helper_models.php
.phpstorm.meta.php
.phpactor.json
.php-cs-fixer.cache
.phpcs-cache

# ===========================================================================
# IDE & EDITORS
# ===========================================================================
/.idea
/.vscode
/.fleet
/.nova
/.zed
*.sublime-project
*.sublime-workspace
*.code-workspace

# ===========================================================================
# OS GENERATED
# ===========================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ===========================================================================
# TEMPORARY & SWAP FILES
# ===========================================================================
*.swp
*.swo
*~
*.tmp
*.temp

# ===========================================================================
# DOCKER (jika dipakai di masa depan)
# ===========================================================================
.docker-sync*
docker-compose.override.yml

# ===========================================================================
# HOMESTEAD / VAGRANT (dev environment lokal)
# ===========================================================================
Homestead.json
Homestead.yaml
Vagrantfile
.vagrant

# ===========================================================================
# KIRO AI ASSISTANT
# ===========================================================================
/.kiro
